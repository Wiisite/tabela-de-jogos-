# Environment variables for dev and production
# Copy this file to .env and fill in the values

# Database
# For local dev with docker-compose: mysql://root:password@localhost:3306/tournament_pro
DATABASE_URL=mysql://root:password@localhost:3306/tournament_pro

# Auth
JWT_SECRET=super-secret-key-change-it-in-production

# OAuth (Optional for local testing if you skip admin actions)
# These are required for the actual login flow
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Built-in Forge API (System)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

NODE_ENV=development
PORT=3000
